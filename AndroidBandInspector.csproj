<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>AndroidBandInspector</AssemblyName>
    <Description>Read-only ADB collector for Android radio band, Korea mobile allocation, and IMS/VoLTE evidence.</Description>
    <PackageProjectUrl>https://github.com/jsheo-mvi/AndroidBandInspector</PackageProjectUrl>
    <RepositoryUrl>https://github.com/jsheo-mvi/AndroidBandInspector</RepositoryUrl>
    <PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
  </PropertyGroup>

</Project>
